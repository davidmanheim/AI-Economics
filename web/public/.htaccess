# Serve index.html at the site root.
DirectoryIndex index.html

# Explicitly allow access — a 403 right after upload is very often caused by
# an inherited "deny all" from a parent .htaccess, or by Apache 2.4's default
# posture with no explicit grant. This forces access open for this directory.
<IfModule mod_authz_core.c>
  # Apache 2.4+
  Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
  # Apache 2.2 and older
  Order allow,deny
  Allow from all
</IfModule>

# Don't auto-generate directory listings (harmless either way since every
# directory here has an index file or is only linked to directly).
Options -Indexes

# Make sure the notebook downloads with a sane type instead of whatever the
# server's default fallback is.
<IfModule mod_mime.c>
  AddType application/octet-stream .ipynb
</IfModule>

# Caching policy. The host runs a dynamic (NGINX) page cache in front of
# Apache; without this, it will store index.html and keep serving it after a
# deploy — but index.html references content-hashed asset filenames that change
# every build, so a cached shell points at bundles that no longer exist (blank
# page), and social scrapers read stale Open Graph tags. Send no-cache on the
# HTML shell so it is always revalidated against the current build, and cache
# the immutable, content-hashed assets hard and long.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
